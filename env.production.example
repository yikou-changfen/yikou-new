# 一口腸粉 Vercel Production 環境變數範本
# 用法：
# 1. 複製成 .env.production.local
# 2. 填入正式值
# 3. 執行 npm run check:env:file
# 4. 到 Vercel Project Settings > Environment Variables 逐項貼上
#
# 注意：不要把 .env.production.local 或正式 secret commit 到 GitHub。

# 正式站網址，用於固定 LINE / Google OAuth redirect URI。
PUBLIC_BASE_URL=https://yikou-cheungfun-line-order-v2.vercel.app

# Google 商家營業資訊
GOOGLE_PLACE_ID=ChIJ0wZdQgA9aTQR-dLMJWRvNEc
GOOGLE_PLACES_API_KEY=

# LINE 店家官方帳號加入好友連結，範例：https://lin.ee/xxxxxxx
LINE_OFFICIAL_ACCOUNT_URL=

# OAuth state / 會員 session 簽章密鑰
# 建議使用 32 bytes 以上隨機值；正式環境至少 SESSION_SECRET 要存在。
OAUTH_STATE_SECRET=
SESSION_SECRET=

# LINE Login
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase 會員資料庫，只能給 serverless API 使用，不可放前端。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# POS / 後台系統呼叫訂單完成 API 使用
POS_API_TOKEN=
