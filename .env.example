# 一口腸粉品牌官網環境變數範例

# Google 商家營業資訊
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJ0wZdQgA9aTQR-dLMJWRvNEc

# 一口腸粉 LINE 官方帳號加入好友連結
# 範例：https://lin.ee/xxxxxxx
LINE_OFFICIAL_ACCOUNT_URL=

# OAuth state / 會員 session 簽章密鑰。請用長隨機字串，勿提交正式值。
# 若既有 Vercel 已有 SESSION_SECRET，可先共用；新專案建議兩者都設。
OAUTH_STATE_SECRET=
SESSION_SECRET=

# LINE Login
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase 會員資料庫
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# POS / 後台系統呼叫訂單完成 API 使用
POS_API_TOKEN=
